@{
    ViewBag.Title = "Mood Tracker";
    var todayMood = ViewBag.TodayMood as MindfulMe_YashDalavi.Models.MoodEntry;
    int streak = ViewBag.StreakCount ?? 0;
    var recentEntries = ViewBag.RecentEntries as System.Collections.Generic.List<MindfulMe_YashDalavi.Models.MoodEntry>;
}

<style>
    .mood-page {
        max-width: 1100px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    .mood-header {
        text-align: center;
        margin-bottom: 40px;
    }

        .mood-header h1 {
            font-size: 2.5rem;
            color: #2D3047;
            margin-bottom: 10px;
        }

        .mood-header p {
            color: #6B7280;
            font-size: 1.1rem;
        }

    .hero-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 25px;
        margin-bottom: 40px;
    }

    .hero-card {
        background: white;
        padding: 35px;
        border-radius: 20px;
        text-align: center;
        box-shadow: 0 4px 20px rgba(108, 99, 255, 0.08);
    }

    .streak-card {
        background: linear-gradient(135deg, #FF6B9D, #FF8E72);
        color: white;
    }

        .streak-card h3 {
            font-size: 1.1rem;
            opacity: 0.95;
            margin-bottom: 10px;
        }

    .streak-number {
        font-size: 4rem;
        font-weight: 800;
        margin: 10px 0;
    }

    .streak-fire {
        font-size: 2.5rem;
    }

    .today-card h3 {
        color: #6C63FF;
        margin-bottom: 15px;
        font-size: 1.1rem;
    }

    .today-emoji {
        font-size: 4rem;
        margin: 10px 0;
    }

    .today-label {
        font-size: 1.3rem;
        font-weight: 600;
        color: #2D3047;
        margin-bottom: 10px;
    }

    .today-note {
        color: #6B7280;
        font-style: italic;
    }

    .cta-card {
        background: linear-gradient(135deg, #6C63FF, #764ba2);
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        .cta-card h3 {
            font-size: 1.3rem;
            margin-bottom: 15px;
        }

    .btn-cta {
        background: white;
        color: #6C63FF;
        padding: 12px 28px;
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        margin-top: 10px;
        transition: transform 0.3s;
    }

        .btn-cta:hover {
            transform: translateY(-3px);
        }

    .recent-section {
        background: white;
        padding: 35px;
        border-radius: 20px;
        box-shadow: 0 4px 20px rgba(108, 99, 255, 0.08);
    }

    .recent-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

        .recent-header h2 {
            color: #2D3047;
        }

    .view-all {
        color: #6C63FF;
        text-decoration: none;
        font-weight: 600;
    }

    .entry-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .entry-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 15px;
        background: #F8F9FC;
        border-radius: 12px;
        transition: transform 0.2s;
    }

        .entry-item:hover {
            transform: translateX(5px);
        }

    .entry-emoji {
        font-size: 2.2rem;
    }

    .entry-details {
        flex: 1;
    }

    .entry-label {
        font-weight: 600;
        color: #2D3047;
    }

    .entry-note {
        color: #6B7280;
        font-size: 0.9rem;
        margin-top: 3px;
    }

    .entry-time {
        color: #9CA3AF;
        font-size: 0.85rem;
    }

    .empty-state {
        text-align: center;
        padding: 40px;
        color: #9CA3AF;
    }

        .empty-state i {
            font-size: 3rem;
            margin-bottom: 15px;
            opacity: 0.5;
        }
</style>

<div class="mood-page">
    <div class="mood-header">
        <h1>How are you feeling today? 💙</h1>
        <p>Track your emotions, spot patterns, build self-awareness.</p>
    </div>

    <div class="hero-cards">
        <div class="hero-card streak-card">
            <h3>Your Streak</h3>
            <div class="streak-fire">🔥</div>
            <div class="streak-number">@streak</div>
            <p>@(streak == 1 ? "day" : "days") in a row</p>
        </div>

        <div class="hero-card today-card">
            <h3><i class="fas fa-calendar-day"></i> Today's Mood</h3>
            @if (todayMood != null)
            {
                <div class="today-emoji">@todayMood.MoodEmoji</div>
                <div class="today-label">@todayMood.MoodLabel</div>
                if (!string.IsNullOrWhiteSpace(todayMood.Note))
                {
                    <p class="today-note">"@todayMood.Note"</p>
                }
            }
            else
            {
                <div class="today-emoji" style="opacity:0.3;">🤔</div>
                <p style="color:#6B7280;">Not logged yet</p>
            }
        </div>

        <div class="hero-card cta-card">
            <h3>@(todayMood != null ? "Update your mood?" : "Log today's mood")</h3>
            <p style="opacity:0.9;">It takes just 10 seconds</p>
            <div>
                <a href="@Url.Action("Add", "Mood")" class="btn-cta">
                    <i class="fas fa-plus"></i> Log Mood
                </a>
            </div>
        </div>
    </div>

    <div class="recent-section">
        <div class="recent-header">
            <h2><i class="fas fa-history"></i> Recent Entries (Last 7 Days)</h2>
            <a href="@Url.Action("History", "Mood")" class="view-all">View All <i class="fas fa-arrow-right"></i></a>
        </div>

        @if (recentEntries != null && recentEntries.Count > 0)
        {
            <div class="entry-list">
                @foreach (var e in recentEntries)
                {
                    <div class="entry-item">
                        <div class="entry-emoji">@e.MoodEmoji</div>
                        <div class="entry-details">
                            <div class="entry-label">@e.MoodLabel</div>
                            @if (!string.IsNullOrWhiteSpace(e.Note))
                            {
                                <div class="entry-note">@e.Note</div>
                            }
                        </div>
                        <div class="entry-time">
                            @e.EntryDate.ToString("dd MMM, hh:mm tt")
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-inbox"></i>
                <p>No entries yet. Start by logging your first mood above!</p>
            </div>
        }
    </div>
</div>