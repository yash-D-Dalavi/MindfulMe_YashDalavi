@model MindfulMe_YashDalavi.Models.Counselor
@{
    ViewBag.Title = Model.FullName;
}

<style>
    .details-page {
        max-width: 900px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    .back-link {
        color: #6C63FF;
        text-decoration: none;
        font-weight: 600;
        margin-bottom: 20px;
        display: inline-block;
    }

    .detail-card {
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 4px 30px rgba(108, 99, 255, 0.1);
    }

    .detail-header {
        background: linear-gradient(135deg, #6C63FF, #764ba2);
        color: white;
        padding: 50px 40px;
        display: flex;
        gap: 30px;
        align-items: center;
    }

    .d-avatar {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: white;
        color: #6C63FF;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    .d-info h1 {
        font-size: 2rem;
        margin-bottom: 8px;
    }

    .d-spec {
        opacity: 0.95;
        font-size: 1.1rem;
        margin-bottom: 12px;
    }

    .d-badges {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .badge {
        background: rgba(255,255,255,0.25);
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 500;
    }

    .detail-body {
        padding: 40px;
    }

    .stat-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat {
        background: #F8F9FC;
        padding: 20px;
        border-radius: 14px;
        text-align: center;
    }

        .stat .icon {
            font-size: 1.8rem;
            color: #6C63FF;
            margin-bottom: 8px;
        }

        .stat .label {
            color: #6B7280;
            font-size: 0.85rem;
        }

        .stat .value {
            color: #2D3047;
            font-weight: 700;
            font-size: 1.1rem;
            margin-top: 4px;
        }

    .section-title {
        color: #2D3047;
        font-size: 1.2rem;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .bio-text {
        color: #4B5563;
        background: #F8F9FC;
        padding: 20px;
        border-radius: 14px;
        border-left: 4px solid #6C63FF;
        margin-bottom: 30px;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 15px;
        margin-bottom: 30px;
    }

    .contact-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 15px;
        background: #F8F9FC;
        border-radius: 12px;
    }

        .contact-item i {
            font-size: 1.3rem;
            color: #6C63FF;
            width: 32px;
        }

        .contact-item small {
            color: #6B7280;
            display: block;
        }

        .contact-item strong {
            color: #2D3047;
        }

    .book-cta {
        background: linear-gradient(135deg, #EEF1FF, #FFE5EC);
        padding: 30px;
        border-radius: 16px;
        text-align: center;
    }

    .fee-display {
        font-size: 2.2rem;
        font-weight: 700;
        color: #6C63FF;
        margin: 10px 0;
    }

    .btn-book-big {
        background: linear-gradient(135deg, #6C63FF, #764ba2);
        color: white;
        padding: 15px 40px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 600;
        display: inline-block;
        margin-top: 10px;
        transition: transform 0.3s;
    }

        .btn-book-big:hover {
            transform: translateY(-3px);
        }
</style>

<div class="details-page">
    <a href="@Url.Action("Index", "Counselor")" class="back-link">
        <i class="fas fa-arrow-left"></i> Back to counselors
    </a>

    <div class="detail-card">
        <div class="detail-header">
            <div class="d-avatar">@(Model.FullName.Length > 0 ? Model.FullName.Substring(0, 1) : "C")</div>
            <div class="d-info">
                <h1>@Model.FullName</h1>
                <div class="d-spec"><i class="fas fa-stethoscope"></i> @Model.Specialization</div>
                <div class="d-badges">
                    <span class="badge"><i class="fas fa-check-circle"></i> Verified</span>
                    <span class="badge"><i class="fas fa-award"></i> @Model.ExperienceYears years experience</span>
                </div>
            </div>
        </div>

        <div class="detail-body">
            <div class="stat-row">
                <div class="stat">
                    <div class="icon"><i class="fas fa-clock"></i></div>
                    <div class="label">Experience</div>
                    <div class="value">@Model.ExperienceYears years</div>
                </div>
                <div class="stat">
                    <div class="icon"><i class="fas fa-rupee-sign"></i></div>
                    <div class="label">Fee per session</div>
                    <div class="value">₹@Model.FeePerSession.ToString("N0")</div>
                </div>
                <div class="stat">
                    <div class="icon"><i class="fas fa-shield-alt"></i></div>
                    <div class="label">Confidential</div>
                    <div class="value">100%</div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Bio))
            {
                <h2 class="section-title"><i class="fas fa-user"></i> About</h2>
                <p class="bio-text">@Model.Bio</p>
            }

            <h2 class="section-title"><i class="fas fa-address-card"></i> Contact</h2>
            <div class="contact-grid">
                <div class="contact-item">
                    <i class="fas fa-envelope"></i>
                    <div>
                        <small>Email</small>
                        <strong>@Model.Email</strong>
                    </div>
                </div>
                <div class="contact-item">
                    <i class="fas fa-phone"></i>
                    <div>
                        <small>Phone</small>
                        <strong>@Model.Phone</strong>
                    </div>
                </div>
            </div>

            <div class="book-cta">
                <p style="color:#6B7280;">Ready to take the next step?</p>
                <div class="fee-display">₹@Model.FeePerSession.ToString("N0")</div>
                <p style="color:#6B7280; margin-bottom:10px;">per counseling session</p>
                <a href="@Url.Action("Book", "Booking", new { counselorId = Model.CounselorId })" class="btn-book-big">
                    <i class="fas fa-calendar-plus"></i> Book a Session
                </a>
            </div>
        </div>
    </div>
</div>