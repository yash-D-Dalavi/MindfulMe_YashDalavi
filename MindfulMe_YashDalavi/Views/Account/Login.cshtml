@using MindfulMe_YashDalavi.Models
@model LoginViewModel
@{
    ViewBag.Title = "Sign In";
}

<style>
    .auth-page {
        min-height: calc(100vh - 200px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        background: linear-gradient(135deg, #EEF1FF 0%, #FFE5EC 100%);
    }

    .auth-card {
        background: white;
        padding: 50px 45px;
        border-radius: 24px;
        box-shadow: 0 10px 40px rgba(108, 99, 255, 0.15);
        width: 100%;
        max-width: 480px;
    }

    .auth-header {
        text-align: center;
        margin-bottom: 35px;
    }

    .auth-icon {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #6C63FF, #764ba2);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        color: white;
        font-size: 1.8rem;
    }

    .auth-header h1 {
        color: #2D3047;
        font-size: 2rem;
        margin-bottom: 8px;
    }

    .auth-header p {
        color: #6B7280;
    }

    .form-field {
        margin-bottom: 20px;
    }

        .form-field label {
            display: block;
            font-weight: 600;
            color: #2D3047;
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

        .form-field input[type=text], .form-field input[type=email], .form-field input[type=password] {
            width: 100%;
            padding: 14px 18px;
            border: 2px solid #E5E7EB;
            border-radius: 12px;
            font-family: inherit;
            font-size: 1rem;
            transition: border-color 0.3s, box-shadow 0.3s;
        }

            .form-field input[type=text]:focus,
            .form-field input[type=email]:focus,
            .form-field input[type=password]:focus {
                outline: none;
                border-color: #6C63FF;
                box-shadow: 0 0 0 3px rgba(108, 99, 255, 0.1);
            }

    .remember-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 20px;
        color: #4B5563;
    }

    .btn-auth {
        width: 100%;
        background: linear-gradient(135deg, #6C63FF, #764ba2);
        color: white;
        padding: 15px;
        border: none;
        border-radius: 12px;
        font-size: 1.05rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }

        .btn-auth:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(108, 99, 255, 0.3);
        }

    .auth-footer {
        text-align: center;
        margin-top: 25px;
        color: #6B7280;
    }

        .auth-footer a {
            color: #6C63FF;
            font-weight: 600;
            text-decoration: none;
        }

            .auth-footer a:hover {
                text-decoration: underline;
            }

    .validation-summary-errors {
        background: #FEE2E2;
        color: #991B1B;
        padding: 12px 16px;
        border-radius: 10px;
        margin-bottom: 20px;
        font-size: 0.9rem;
    }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 20px;
        }

    .validation-error {
        color: #DC2626;
        font-size: 0.85rem;
        margin-top: 6px;
    }
</style>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-icon"><i class="fas fa-sign-in-alt"></i></div>
            <h1>Welcome Back 👋</h1>
            <p>Sign in to continue your journey</p>
        </div>

        @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="form-field">
                @Html.LabelFor(m => m.Email)
                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "you@example.com", autofocus = "autofocus" })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "validation-error" })
            </div>

            <div class="form-field">
                @Html.LabelFor(m => m.Password)
                @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Your password" })
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "validation-error" })
            </div>

            <div class="remember-row">
                @Html.CheckBoxFor(m => m.RememberMe) @Html.LabelFor(m => m.RememberMe)
            </div>

            <button type="submit" class="btn-auth">
                <i class="fas fa-sign-in-alt"></i> Sign In
            </button>
        }

        <div class="auth-footer">
            New to MindfulMe? @Html.ActionLink("Create an account", "Register")
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}