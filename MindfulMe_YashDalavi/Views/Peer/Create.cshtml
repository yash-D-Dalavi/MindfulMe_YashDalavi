@{
    ViewBag.Title = "Share Anonymously";
    string suggestedName = ViewBag.SuggestedName as string ?? "Anonymous";

    var moodTags = new[] { "Anxious", "Sad", "Happy", "Stressed", "Grateful", "Lonely", "Motivated", "Confused" };
}

<style>
    .create-page {
        max-width: 700px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    .back-link {
        color: #6C63FF;
        text-decoration: none;
        font-weight: 600;
        margin-bottom: 20px;
        display: inline-block;
    }

    .create-card {
        background: white;
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 4px 30px rgba(108, 99, 255, 0.1);
    }

        .create-card h1 {
            color: #2D3047;
            font-size: 1.8rem;
            margin-bottom: 8px;
            text-align: center;
        }

        .create-card .subtitle {
            color: #6B7280;
            text-align: center;
            margin-bottom: 30px;
        }

    .identity-box {
        background: linear-gradient(135deg, #EEF1FF, #FFE5EC);
        padding: 20px;
        border-radius: 14px;
        margin-bottom: 25px;
        text-align: center;
    }

    .identity-avatar {
        width: 55px;
        height: 55px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6C63FF, #FF6B9D);
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .identity-box h3 {
        color: #6C63FF;
        margin-bottom: 5px;
        font-size: 1.1rem;
    }

    .identity-box p {
        color: #6B7280;
        font-size: 0.85rem;
        margin-bottom: 10px;
    }

    .regenerate-btn {
        background: white;
        border: 2px solid #6C63FF;
        color: #6C63FF;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
    }

    .form-section {
        margin-bottom: 22px;
    }

        .form-section label {
            display: block;
            font-weight: 600;
            color: #2D3047;
            margin-bottom: 10px;
        }

    .mood-selector {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .mood-choice {
        padding: 8px 16px;
        border: 2px solid #E5E7EB;
        background: white;
        color: #4B5563;
        border-radius: 50px;
        cursor: pointer;
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.3s;
        font-family: inherit;
    }

        .mood-choice.selected {
            background: linear-gradient(135deg, #6C63FF, #764ba2);
            color: white;
            border-color: #6C63FF;
        }

    .content-area {
        width: 100%;
        padding: 16px;
        border: 2px solid #E5E7EB;
        border-radius: 14px;
        font-family: inherit;
        font-size: 1rem;
        resize: vertical;
        min-height: 150px;
    }

        .content-area:focus {
            outline: none;
            border-color: #6C63FF;
        }

    .char-counter {
        text-align: right;
        color: #9CA3AF;
        font-size: 0.85rem;
        margin-top: 5px;
    }

    .btn-post {
        width: 100%;
        background: linear-gradient(135deg, #6C63FF, #764ba2);
        color: white;
        padding: 15px;
        border: none;
        border-radius: 12px;
        font-size: 1.05rem;
        font-weight: 600;
        cursor: pointer;
        font-family: inherit;
        transition: all 0.3s;
    }

        .btn-post:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(108, 99, 255, 0.3);
        }
</style>

<div class="create-page">
    <a href="@Url.Action("Index", "Peer")" class="back-link">
        <i class="fas fa-arrow-left"></i> Back to wall
    </a>

    <div class="create-card">
        <h1>Share your thoughts 💭</h1>
        <p class="subtitle">Your identity stays anonymous. Your feelings matter.</p>

        @using (Html.BeginForm("Create", "Peer", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="identity-box">
                <div class="identity-avatar" id="avatarLetter">@suggestedName.Substring(0, 1)</div>
                <h3 id="nameDisplay">@suggestedName</h3>
                <p>This is your anonymous identity</p>
                <input type="hidden" name="anonymousName" id="anonymousName" value="@suggestedName" />
            </div>

            <div class="form-section">
                <label><i class="fas fa-heart"></i> How are you feeling? (optional)</label>
                <input type="hidden" name="moodTag" id="moodTag" value="" />
                <div class="mood-selector">
                    @foreach (var m in moodTags)
                    {
                        <button type="button" class="mood-choice" data-mood="@m">@m</button>
                    }
                </div>
            </div>

            <div class="form-section">
                <label><i class="fas fa-pen"></i> Your thoughts</label>
                <textarea name="content" class="content-area" maxlength="1000"
                          placeholder="What's on your mind? No judgment here..." required></textarea>
                <div class="char-counter"><span id="charCount">0</span> / 1000</div>
            </div>

            <button type="submit" class="btn-post">
                <i class="fas fa-paper-plane"></i> Post to Wall
            </button>
        }
    </div>
</div>

@section scripts {
    <script>
        (function () {
            var moodBtns = document.querySelectorAll('.mood-choice');
            var moodInput = document.getElementById('moodTag');

            moodBtns.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    if (btn.classList.contains('selected')) {
                        btn.classList.remove('selected');
                        moodInput.value = '';
                    } else {
                        moodBtns.forEach(function (b) { b.classList.remove('selected'); });
                        btn.classList.add('selected');
                        moodInput.value = btn.getAttribute('data-mood');
                    }
                });
            });

            var textarea = document.querySelector('.content-area');
            var counter = document.getElementById('charCount');
            textarea.addEventListener('input', function () {
                counter.textContent = textarea.value.length;
            });
        })();
    </script>
}