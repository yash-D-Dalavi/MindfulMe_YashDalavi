@{
    ViewBag.Title = "My Dashboard";
    string userEmail = ViewBag.UserEmail as string ?? "";
    var todayMood = ViewBag.TodayMood as MindfulMe_YashDalavi.Models.MoodEntry;
    int streak = ViewBag.StreakCount ?? 0;
    var recentMoods = ViewBag.RecentMoods as System.Collections.Generic.List<MindfulMe_YashDalavi.Models.MoodEntry>;
    var distribution = ViewBag.MoodDistribution as System.Collections.Generic.Dictionary<string, int>;
    int totalMinutes = ViewBag.TotalMinutes ?? 0;
    var completions = ViewBag.RecentCompletions as System.Collections.Generic.List<MindfulMe_YashDalavi.Models.ActivityCompletion>;
    var bookings = ViewBag.UserBookings as System.Collections.Generic.List<MindfulMe_YashDalavi.Models.CounselorBooking>;

    int completedActivities = completions != null ? completions.Count : 0;

    int upcomingBookings = 0;
    if (bookings != null)
    {
        foreach (var b in bookings)
        {
            if (b.Status == "Pending" || b.Status == "Confirmed")
            {
                upcomingBookings = upcomingBookings + 1;
            }
        }
    }

    int totalMoodEntries = 0;
    if (distribution != null)
    {
        foreach (var v in distribution.Values)
        {
            totalMoodEntries = totalMoodEntries + v;
        }
    }

    string firstLetter = userEmail.Length > 0 ? userEmail.Substring(0, 1).ToUpper() : "U";
    string userName = userEmail.Contains("@") ? userEmail.Split('@')[0] : userEmail;

    int distVerySad = distribution != null ? distribution["Very Sad"] : 0;
    int distSad = distribution != null ? distribution["Sad"] : 0;
    int distNeutral = distribution != null ? distribution["Neutral"] : 0;
    int distHappy = distribution != null ? distribution["Happy"] : 0;
    int distVeryHappy = distribution != null ? distribution["Very Happy"] : 0;
}

<style>
    .dash-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 30px 20px;
    }

    .welcome-banner {
        background: linear-gradient(135deg, #6C63FF, #764ba2);
        color: white;
        padding: 40px;
        border-radius: 24px;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 25px;
    }

    .welcome-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: rgba(255,255,255,0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    .welcome-text h1 {
        font-size: 1.8rem;
        margin-bottom: 5px;
    }

    .welcome-text p {
        opacity: 0.95;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        padding: 25px;
        border-radius: 18px;
        box-shadow: 0 4px 20px rgba(108, 99, 255, 0.08);
    }

        .stat-card .icon-wrap {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: white;
            margin-bottom: 15px;
        }

        .stat-card .label {
            color: #6B7280;
            font-size: 0.85rem;
            margin-bottom: 5px;
        }

        .stat-card .value {
            color: #2D3047;
            font-size: 2rem;
            font-weight: 800;
        }

        .stat-card .sub {
            color: #9CA3AF;
            font-size: 0.8rem;
            margin-top: 5px;
        }

    .icon-orange {
        background: linear-gradient(135deg, #FF6B9D, #FF8E72);
    }

    .icon-purple {
        background: linear-gradient(135deg, #6C63FF, #764ba2);
    }

    .icon-green {
        background: linear-gradient(135deg, #10B981, #34D399);
    }

    .icon-blue {
        background: linear-gradient(135deg, #3B82F6, #6366F1);
    }

    .main-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 25px;
        margin-bottom: 30px;
    }

    .panel {
        background: white;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 4px 20px rgba(108, 99, 255, 0.08);
    }

    .panel-title {
        color: #2D3047;
        margin-bottom: 20px;
        font-size: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .panel-title a {
            color: #6C63FF;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
        }

    .chart-box {
        height: 250px;
        position: relative;
    }

    .today-mood-box {
        text-align: center;
        padding: 30px 20px;
    }

    .today-emoji {
        font-size: 4rem;
        margin-bottom: 15px;
    }

    .today-label {
        color: #2D3047;
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .today-note {
        color: #6B7280;
        font-style: italic;
        font-size: 0.9rem;
    }

    .btn-log-mood {
        display: inline-block;
        background: linear-gradient(135deg, #6C63FF, #764ba2);
        color: white;
        padding: 12px 28px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 600;
        margin-top: 15px;
    }

    .booking-list, .activity-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .mini-card {
        background: #F8F9FC;
        border-radius: 12px;
        padding: 15px;
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .mini-icon {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6C63FF, #FF6B9D);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        flex-shrink: 0;
    }

    .mini-details {
        flex: 1;
    }

        .mini-details .title {
            color: #2D3047;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .mini-details .meta {
            color: #6B7280;
            font-size: 0.8rem;
            margin-top: 2px;
        }

    .status-small {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .st-Pending {
        background: #FEF3C7;
        color: #92400E;
    }

    .st-Confirmed {
        background: #DBEAFE;
        color: #1E40AF;
    }

    .st-Completed {
        background: #D1FAE5;
        color: #065F46;
    }

    .st-Cancelled {
        background: #FEE2E2;
        color: #991B1B;
    }

    .empty-mini {
        text-align: center;
        color: #9CA3AF;
        padding: 25px;
        font-size: 0.9rem;
    }

    .quick-actions {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
    }

    .action-tile {
        background: white;
        padding: 25px 20px;
        border-radius: 16px;
        text-align: center;
        text-decoration: none;
        color: #2D3047;
        box-shadow: 0 4px 15px rgba(108, 99, 255, 0.06);
        transition: all 0.3s;
    }

        .action-tile:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(108, 99, 255, 0.15);
        }

        .action-tile .a-icon {
            font-size: 2rem;
            color: #6C63FF;
            margin-bottom: 10px;
        }

        .action-tile .a-label {
            font-weight: 600;
            display: block;
        }

        .action-tile .a-sub {
            color: #9CA3AF;
            font-size: 0.8rem;
            margin-top: 4px;
        }

    @@media (max-width: 860px) {
        .main-grid {
            grid-template-columns: 1fr;
        }

        .welcome-banner {
            flex-direction: column;
            text-align: center;
        }
    }
</style>

<div class="dash-page">
    <div class="welcome-banner">
        <div class="welcome-avatar">@firstLetter</div>
        <div class="welcome-text">
            <h1>Welcome back, @userName 👋</h1>
            <p>Your wellness journey at a glance. Small steps, big impact.</p>
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="icon-wrap icon-orange"><i class="fas fa-fire"></i></div>
            <div class="label">Mood Streak</div>
            <div class="value">@streak</div>
            <div class="sub">@(streak == 1 ? "day" : "days") in a row</div>
        </div>

        <div class="stat-card">
            <div class="icon-wrap icon-purple"><i class="fas fa-smile"></i></div>
            <div class="label">Mood Entries</div>
            <div class="value">@totalMoodEntries</div>
            <div class="sub">in last 30 days</div>
        </div>

        <div class="stat-card">
            <div class="icon-wrap icon-green"><i class="fas fa-leaf"></i></div>
            <div class="label">Minutes of self-care</div>
            <div class="value">@totalMinutes</div>
            <div class="sub">@completedActivities activities done</div>
        </div>

        <div class="stat-card">
            <div class="icon-wrap icon-blue"><i class="fas fa-calendar-check"></i></div>
            <div class="label">Upcoming Sessions</div>
            <div class="value">@upcomingBookings</div>
            <div class="sub">counselor bookings</div>
        </div>
    </div>

    <div class="main-grid">
        <div class="panel">
            <div class="panel-title">
                <span><i class="fas fa-chart-bar"></i> Mood Distribution (Last 30 days)</span>
                <a href="@Url.Action("History", "Mood")">Full report →</a>
            </div>
            <div class="chart-box">
                <canvas id="moodChart"></canvas>
            </div>
        </div>

        <div class="panel">
            <div class="panel-title">
                <span><i class="fas fa-calendar-day"></i> Today's Mood</span>
            </div>
            <div class="today-mood-box">
                @if (todayMood != null)
                {
                    <div class="today-emoji">@todayMood.MoodEmoji</div>
                    <div class="today-label">@todayMood.MoodLabel</div>
                    if (!string.IsNullOrWhiteSpace(todayMood.Note))
                    {
                        <div class="today-note">"@todayMood.Note"</div>
                    }
                }
                else
                {
                    <div class="today-emoji" style="opacity:0.3;">🤔</div>
                    <div class="today-label" style="color:#9CA3AF;">Not logged yet</div>
                    <a href="@Url.Action("Add", "Mood")" class="btn-log-mood">
                        <i class="fas fa-plus"></i> Log Now
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="main-grid">
        <div class="panel">
            <div class="panel-title">
                <span><i class="fas fa-calendar-alt"></i> Your Bookings</span>
                <a href="@Url.Action("MyBookings", "Booking")">View all →</a>
            </div>

            @if (bookings != null && bookings.Count > 0)
            {
                <div class="booking-list">
                    @foreach (var b in bookings.Take(3))
                    {
                        <div class="mini-card">
                            <div class="mini-icon">@(b.CounselorName.Length > 0 ? b.CounselorName.Substring(0, 1) : "C")</div>
                            <div class="mini-details">
                                <div class="title">@b.CounselorName</div>
                                <div class="meta">@b.SessionDate.ToString("dd MMM, hh:mm tt") · ₹@b.AmountPaid.ToString("N0")</div>
                            </div>
                            <span class="status-small st-@b.Status">@b.Status</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-mini">
                    <i class="fas fa-calendar-times" style="font-size:2rem; opacity:0.4;"></i>
                    <p style="margin-top:10px;">No bookings yet. <a href="@Url.Action("Index", "Counselor")" style="color:#6C63FF;">Find a counselor</a></p>
                </div>
            }
        </div>

        <div class="panel">
            <div class="panel-title">
                <span><i class="fas fa-leaf"></i> Recent Activities</span>
                <a href="@Url.Action("Index", "Activity")">Start new →</a>
            </div>

            @if (completions != null && completions.Count > 0)
            {
                <div class="activity-list">
                    @foreach (var a in completions.Take(3))
                    {
                        <div class="mini-card">
                            <div class="mini-icon" style="background: linear-gradient(135deg, #10B981, #34D399);"><i class="fas fa-check"></i></div>
                            <div class="mini-details">
                                <div class="title">@a.ActivityTitle</div>
                                <div class="meta">@a.ActivityCategory · @a.CompletedOn.ToString("dd MMM")</div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-mini">
                    <i class="fas fa-seedling" style="font-size:2rem; opacity:0.4;"></i>
                    <p style="margin-top:10px;">Try a breathing exercise today!</p>
                </div>
            }
        </div>
    </div>

    <div class="panel">
        <div class="panel-title"><span><i class="fas fa-bolt"></i> Quick Actions</span></div>
        <div class="quick-actions">
            <a href="@Url.Action("Add", "Mood")" class="action-tile">
                <div class="a-icon"><i class="fas fa-smile-beam"></i></div>
                <span class="a-label">Log Mood</span>
                <div class="a-sub">10 seconds</div>
            </a>
            <a href="@Url.Action("Index", "Activity")" class="action-tile">
                <div class="a-icon"><i class="fas fa-wind"></i></div>
                <span class="a-label">Breathe</span>
                <div class="a-sub">3–15 min</div>
            </a>
            <a href="@Url.Action("Index", "Counselor")" class="action-tile">
                <div class="a-icon"><i class="fas fa-user-md"></i></div>
                <span class="a-label">Counselors</span>
                <div class="a-sub">Book session</div>
            </a>
            <a href="@Url.Action("Index", "Peer")" class="action-tile">
                <div class="a-icon"><i class="fas fa-comments"></i></div>
                <span class="a-label">Peer Wall</span>
                <div class="a-sub">Share &amp; support</div>
            </a>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            var ctx = document.getElementById('moodChart');
            if (!ctx) return;

            var values = [@distVerySad, @distSad, @distNeutral, @distHappy, @distVeryHappy];
            var labels = ['Very Sad', 'Sad', 'Neutral', 'Happy', 'Very Happy'];
            var colors = ['#EF4444', '#F87171', '#FBBF24', '#34D399', '#10B981'];

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Days',
                        data: values,
                        backgroundColor: colors,
                        borderRadius: 10,
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { stepSize: 1, color: '#6B7280' },
                            grid: { color: '#F3F4F6' }
                        },
                        x: {
                            ticks: { color: '#6B7280' },
                            grid: { display: false }
                        }
                    }
                }
            });
        })();
    </script>
}